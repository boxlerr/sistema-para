# ============================================================================
# SistemasPara.com — Variables de entorno
# Copiá este archivo a .env.local y completá los valores.
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase
# Dashboard: https://supabase.com/dashboard/project/<project-id>/settings/api-keys
# ----------------------------------------------------------------------------

# URL pública del proyecto Supabase. Visible en cliente y servidor.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (sb_publishable_...) o legacy anon key (eyJ...).
# Es segura para exponer al browser SI hay RLS configurado correctamente.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Secret key (sb_secret_...) o legacy service_role JWT (eyJ...).
# ⚠️ NUNCA exponer al cliente — bypass de RLS. Solo usada por el script
# Python en /scripts y por Server Actions / Route Handlers privados.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# Google Gemini API (motor SEO programático)
# Conseguir gratis en: https://aistudio.google.com/apikey
# ----------------------------------------------------------------------------
GEMINI_API_KEY=AIza...

# ----------------------------------------------------------------------------
# Site
# URL canónica del sitio en producción. Se usa en:
#   - <link rel="canonical">
#   - Open Graph / Twitter Card URLs
#   - sitemap.xml
#   - robots.txt
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://sistemaspara.com
